# gdoc — copy to .env (gitignored) and fill in. NEVER put real keys in this file.

# CLI (server-side, RLS-bypassing — secret, NEVER ship to client/bundle, NEVER commit)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Owner's Supabase Auth user id (optional). Stamped on uploaded rows so the owner
# can read PRIVATE docs after logging into the viewer. Leave blank until you have it.
OWNER_UID=

# Viewer (client-side — safe to expose; protected by RLS)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
